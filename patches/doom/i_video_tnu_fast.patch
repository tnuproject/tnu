+ * to expand the 8-bit Doom framebuffer into a full-resolution RGB buffer
+ * inside i_video.c, and doomgeneric_tnu.c could scale/blit again afterwards.
+ * On real hardware this means massive uncached framebuffer traffic and can
+ * drop to ~1 FPS.
+ */
+#ifndef TNU_DOOM_FAST_NATIVE
+#define TNU_DOOM_FAST_NATIVE 1
+#endif
