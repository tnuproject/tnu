{
  "ports": [
    {
      "name": "alpine-chroot",
      "kind": "compat",
      "upstream": "Alpine Linux",
      "source": "https://dl-cdn.alpinelinux.org/alpine/v3.20/releases/x86_64/alpine-minirootfs-3.20.0-x86_64.tar.gz",
      "license": "MIT",
      "target_binary": "/usr/linux/bin/busybox",
      "required_features": [
        "linux_compat_exec",
        "linux_compat_syscalls"
      ],
      "dependencies": [
        "linux_compat"
      ],
      "notes": "Alpine Linux minirootfs for Linux ABI compatibility. nano and freedoom are installed via apk."
    },
    {
      "name": "fastfetch",
      "kind": "system-info",
      "upstream": "tnu-native",
      "source": "ports/fastfetch/src/fastfetch.c",
      "license": "MIT",
      "target_binary": "/usr/bin/fastfetch",
      "required_features": [
        "exec",
        "proc_filesystem",
        "framebuffer_ioctl",
        "tty_ioctl",
        "filesystem_read"
      ],
      "dependencies": [
        "libc"
      ]
    },
    {
      "name": "git",
      "kind": "vcs",
      "upstream": "Git",
      "source": "https://github.com/git/git.git",
      "license": "GPL-2.0-only",
      "target_binary": "/usr/bin/git",
      "required_features": [
        "exec",
        "tcp",
        "sockets",
        "dns",
        "select_poll",
        "fork_or_spawn_profile",
        "pipe",
        "filesystem_read",
        "filesystem_write",
        "filesystem_rename_unlink",
        "stat_lstat_fstat",
        "environment",
        "time",
        "crypto_hashes",
        "zlib"
      ],
      "dependencies": [
        "libc",
        "zlib",
        "openssl-or-tiny-sha1",
        "curl-optional-for-http-transport",
        "pcre2-optional"
      ]
    },
    {
      "name": "curl",
      "kind": "network-tool",
      "upstream": "curl",
      "source": "https://curl.se/download/curl.tar.xz",
      "license": "curl",
      "target_binary": "/usr/bin/curl",
      "required_features": [
        "exec",
        "tcp",
        "sockets",
        "dns",
        "select_poll",
        "tls_or_no_tls_profile",
        "filesystem_write"
      ],
      "dependencies": [
        "libc",
        "zlib-optional",
        "mbedtls-or-bearssl-optional"
      ]
    },
    {
      "name": "wget",
      "kind": "network-tool",
      "upstream": "GNU Wget",
      "source": "https://ftp.gnu.org/gnu/wget/wget-latest.tar.gz",
      "license": "GPL-3.0-or-later",
      "target_binary": "/usr/bin/wget",
      "required_features": [
        "exec",
        "tcp",
        "sockets",
        "dns",
        "select_poll",
        "filesystem_write"
      ],
      "dependencies": [
        "libc",
        "gnulib-subset",
        "tls-optional"
      ]
    },
    {
      "name": "xorg",
      "kind": "display-server",
      "upstream": "X.Org modular tree",
      "source": "https://gitlab.freedesktop.org/xorg/xserver.git",
      "license": "MIT/X11",
      "target_binary": "/usr/bin/Xorg",
      "required_features": [
        "exec",
        "mmap",
        "shared_memory",
        "signals",
        "sockets",
        "select_poll",
        "ioctl",
        "userspace_graphics",
        "input_events",
        "dynamic_loader"
      ],
      "dependencies": [
        "libc",
        "libdrm-or-fbdev-backend",
        "pixman",
        "xproto",
        "xtrans"
      ]
    },
    {
      "name": "xbrowser",
      "kind": "web-browser",
      "upstream": "TNU simple X11 browser",
      "source": "ports/xbrowser",
      "license": "BSD-2-Clause",
      "target_binary": "/usr/bin/xbrowser",
      "required_features": [
        "exec",
        "xorg",
        "tcp",
        "sockets",
        "dns",
        "http_client",
        "font_rendering"
      ],
      "dependencies": [
        "libc",
        "xlib-or-tinyxlib"
      ]
    }
  ]
}
